# Local development/test template. Production values are managed by DevFactory-Ops SealedSecrets or GitHub Actions build secrets.
# backend
BACKEND_PORT=8000
DEV_BACKEND_PORT=8001
ENV=development

# DB (Supabase PostgreSQL - Transaction pooler)
# Supabase Dashboard > Settings > Database > Connection string (Transaction pooler)
# Production GitOps runtime secret: used by event-bingo-backend-runtime-secrets.
DB_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres
TEST_DB_URL=postgresql+asyncpg://event_bingo_test:event_bingo_test@127.0.0.1:55432/event_bingo_test
TEST_POSTGRES_PORT=55432

# Swagger docs auth
# Production GitOps runtime secret: used by event-bingo-backend-runtime-secrets.
SWAGGER_USERNAME=change-me-swagger-user
SWAGGER_PASSWORD=change-me-swagger-password

# Supabase Auth
# Production GitOps runtime secret: SUPABASE_URL and SUPABASE_KEY are used by event-bingo-backend-runtime-secrets.
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=your-supabase-anon-key
# Optional/local fallback only: not currently present in the production GitOps sealed secret.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Admin
# Legacy/unused in current code path: docker-compose references this, but production GitOps and app code do not currently use it directly.
ADMIN_JWT_SECRET=change-me-admin-secret
# Admin console URL included in event-manager approval emails.
# For private/dev deployment, set this to https://bingo-private.pseudolab-devfactory.com/admin.
ADMIN_CONSOLE_URL_BASE=http://localhost/admin
# Optional/local admin invite token settings: app code has defaults.
ADMIN_INVITE_TOKEN_EXPIRE_HOURS=72
# Optional/local admin invite URL: app code has a default; not currently present in the production GitOps sealed secret.
ADMIN_INVITE_URL_BASE=http://localhost/admin/invite
# Optional manager request webhook notification. Keep production URL in DevFactory-Ops SealedSecret only.
ADMIN_MANAGER_REQUEST_WEBHOOK_URL=
ADMIN_MANAGER_REQUEST_WEBHOOK_PROVIDER=discord
ADMIN_MANAGER_REQUEST_WEBHOOK_USER_AGENT=EventBingoWebhook/1.0

# Admin SMTP (어드민 초대 메일 — 미설정 시 이메일 발송 비활성화)
# Optional feature env: app code uses these when email sending is enabled.
# Not currently present in the production GitOps sealed secret, so the deployed service runs with invite-email sending disabled/defaulted.
ADMIN_SMTP_HOST=
ADMIN_SMTP_PORT=587
ADMIN_SMTP_USERNAME=
ADMIN_SMTP_PASSWORD=
ADMIN_SMTP_FROM_EMAIL=
ADMIN_SMTP_FROM_NAME=DevFactory 운영팀
ADMIN_SMTP_REPLY_TO=devfactory.ops@gmail.com
ADMIN_SMTP_USE_TLS=true
ADMIN_SMTP_USE_SSL=false

# Privacy retention automation (행사 종료 1년 후 개인식별정보 익명화)
# Optional feature env: app code has defaults.
# Not currently present in the production GitOps sealed secret.
PRIVACY_PERSONAL_DATA_RETENTION_DAYS=365
PRIVACY_REDACTION_RUN_ON_STARTUP=false

# Public URL / SEO rendering
EVENT_SLUG_SALT=event-bingo-auto-slug
PUBLIC_SITE_ORIGIN=http://localhost
PUBLIC_OG_IMAGE_URL=http://localhost/images/hero-networking.jpg
# Optional SSR fallback targets.
FRONTEND_ORIGIN=http://frontend
FRONTEND_INDEX_URL=http://frontend/

# frontend
FRONTEND_PORT=80
DEV_FRONTEND_PORT=3001
# Frontend values are build-time GitHub Actions secrets for production images, not Kubernetes runtime env.
VITE_API_URL=http://localhost:8000
VITE_DEV_API_PROXY_TARGET=http://localhost:8000
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_TEST_MODE=false
VITE_APP_VERSION=
VITE_GIT_SHA=
